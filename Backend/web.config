<?xml version="1.0" encoding="utf-8"?>
<!--
  dotnet publish injects the <aspNetCore> handler + AspNetCoreModuleV2 into this file at publish
  time. We pre-declare the WebDAV removals here so they survive that transform: IIS's WebDAV module
  otherwise grabs DELETE/PUT verbs and returns "405 Method Not Allowed" before the request ever
  reaches the API (e.g. DELETE /api/ExcelExport/{id}). REST APIs don't use WebDAV, so removing it
  is safe.
-->
<configuration>
  <system.webServer>
    <modules>
      <remove name="WebDAVModule" />
    </modules>
    <handlers>
      <remove name="WebDAV" />
    </handlers>
  </system.webServer>
</configuration>
